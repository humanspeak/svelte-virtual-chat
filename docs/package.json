{
    "name": "docs",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "tsx ./scripts/fetch-github-stats.ts && vite build",
        "build:indexnow": "tsx ./scripts/fetch-github-stats.ts && vite build --mode indexnow",
        "cf-typegen": "wrangler types && mv worker-configuration.d.ts src/",
        "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
        "deploy": "pnpm run build:indexnow && wrangler deploy",
        "dev": "vite dev",
        "preview": "vite preview"
    },
    "dependencies": {
        "@fontsource-variable/inter": "^5.2.8",
        "@fontsource-variable/jetbrains-mono": "^5.2.8",
        "@humanspeak/docs-kit": "github:humanspeak/docs-kit#2026.7.2",
        "@humanspeak/svelte-markdown": "^1.6.0",
        "@humanspeak/svelte-motion": "^0.7.3",
        "@humanspeak/svelte-virtual-chat": "workspace:*"
    },
    "devDependencies": {
        "@icons-pack/svelte-simple-icons": "^7.2.0",
        "@lucide/svelte": "^1.21.0",
        "@sveltejs/adapter-cloudflare": "^7.2.9",
        "@sveltejs/kit": "^2.66.0",
        "@sveltejs/vite-plugin-svelte": "^7.1.2",
        "@tailwindcss/typography": "^0.5.20",
        "@tailwindcss/vite": "^4.3.1",
        "eslint": "^10.5.0",
        "mdsvex": "^0.12.7",
        "mode-watcher": "^1.1.0",
        "prettier": "^3.8.4",
        "prettier-plugin-svelte": "^4.1.1",
        "prettier-plugin-tailwindcss": "^0.8.0",
        "shiki": "^4.2.0",
        "svelte": "^5.56.4",
        "svelte-check": "^4.6.0",
        "tailwindcss": "^4.3.1",
        "tsx": "^4.22.4",
        "typescript": "^6.0.3",
        "vite": "^8.0.16",
        "wrangler": "^4.103.0"
    },
    "volta": {
        "node": "24.16.0"
    }
}
